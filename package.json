{
  "name": "garden-planner",
  "private": true,
  "version": "0.0.0",
  "description": "Local-first, voice-led, accessibility-first spatial garden planner for small home growers in Chepinci (Sofia basin).",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "prepare": "husky",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:coverage": "turbo run test -- --coverage",
    "spell": "cspell --no-must-find-files --gitignore \"**/*.{ts,tsx,md}\"",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,yml,yaml}\"",
    "audit:deps": "pnpm audit --audit-level=high || true",
    "audit:citations": "pnpm --filter @garden/engine run audit:citations",
    "audit:contrast": "pnpm --filter @garden/ui run audit:contrast",
    "check:all": "pnpm typecheck && pnpm lint && pnpm test && pnpm spell && pnpm format:check && pnpm audit:citations && pnpm audit:contrast",
    "dev": "bash scripts/dev.sh",
    "dev:stop": "bash scripts/dev-stop.sh",
    "doctor": "bash scripts/doctor.sh",
    "apk": "pnpm --filter apps-mobile run apk:local",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@cspell/dict-typescript": "^3.2.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.9.0",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "cross-env": "^10.1.0",
    "cspell": "^10.0.0",
    "eslint": "^9.14.0",
    "eslint-plugin-import": "^2.31.0",
    "husky": "^9.1.6",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.10",
    "node-gyp": "^12.3.0",
    "prettier": "^3.3.3",
    "react-test-renderer": "19.2.5",
    "ts-jest": "^29.2.5",
    "tsx": "^4.21.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "cross-env ESLINT_USE_FLAT_CONFIG=false eslint --fix --no-error-on-unmatched-pattern"
    ],
    "*.md": [
      "cspell --no-must-find-files --gitignore"
    ]
  },
  "dependencies": {
    "@tanstack/react-query": "^5.99.2",
    "react": "^19.2.5",
    "zustand": "^5.0.12"
  }
}
