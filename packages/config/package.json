{
  "name": "@garden/config",
  "version": "0.0.0",
  "private": true,
  "description": "Shared enums, typed constants, error factory, and cross-package TypeScript types.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
