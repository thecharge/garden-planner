{
  "name": "@garden/memory",
  "version": "0.0.0",
  "private": true,
  "description": "Local-first MemoryRepository over SQLite (expo-sqlite on device, better-sqlite3 for tests).",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint \"src/**/*.ts\"",
    "test": "jest --passWithNoTests",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@garden/config": "workspace:*",
    "@garden/core": "workspace:*"
  },
  "devDependencies": {
    "better-sqlite3": "^11.3.0",
    "@types/better-sqlite3": "^7.6.11"
  },
  "peerDependencies": {
    "expo-sqlite": "*"
  },
  "peerDependenciesMeta": {
    "expo-sqlite": { "optional": true }
  }
}
