{
  "name": "@garden/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Accessible theme tokens and primitive components (wraps react-native-paper). Neutral pastel + dark + AAA.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint \"src/**/*.{ts,tsx}\"",
    "test": "jest --passWithNoTests",
    "audit:contrast": "tsx src/scripts/audit-contrast.ts",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@garden/config": "workspace:*",
    "@garden/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": "*",
    "react-native-paper": "*",
    "expo-haptics": "*",
    "expo-speech": "*"
  },
  "peerDependenciesMeta": {
    "react-native": { "optional": true },
    "react-native-paper": { "optional": true },
    "expo-haptics": { "optional": true },
    "expo-speech": { "optional": true }
  },
  "devDependencies": {
    "ts-node": "^10.9.2"
  }
}
